# =============================================================================
# kweaver-eval configuration
#
# All required config keys are declared here.
# Values resolve in order: shell env > ~/.env.secrets > .env
# Copy this file to .env and fill in your values.
# =============================================================================

# -- Platform -----------------------------------------------------------------
# KWeaver platform URL (required)
KWEAVER_BASE_URL=https://dip-poc.aishu.cn

# Business domain (default: bd_public)
KWEAVER_BUSINESS_DOMAIN=bd_public

# Set to 0 if platform uses self-signed certificate
NODE_TLS_REJECT_UNAUTHORIZED=0

# -- Authentication -----------------------------------------------------------
# Credentials for `kweaver auth login`. Can also be set in ~/.env.secrets.
KWEAVER_USERNAME=
KWEAVER_PASSWORD=

# -- Database (for lifecycle tests) ------------------------------------------
# Used by BKN and Vega lifecycle tests. Can also be set in ~/.env.secrets.
KWEAVER_TEST_DB_TYPE=mysql
KWEAVER_TEST_DB_HOST=
KWEAVER_TEST_DB_PORT=3306
KWEAVER_TEST_DB_NAME=kweaver_eval_test
KWEAVER_TEST_DB_USER=
KWEAVER_TEST_DB_PASS=

# -- Feature flags ------------------------------------------------------------
# Enable agent judge scoring (requires ANTHROPIC_API_KEY)
# EVAL_AGENT_JUDGE=1

# Generate aggregate health report
# EVAL_REPORT=1

# -- API keys -----------------------------------------------------------------
# Required when EVAL_AGENT_JUDGE=1
# ANTHROPIC_API_KEY=
