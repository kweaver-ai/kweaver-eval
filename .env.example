# Required: KWeaver platform URL
KWEAVER_BASE_URL=https://dev.kweaver.example.com

# Authentication
KWEAVER_USERNAME=
KWEAVER_PASSWORD=

# Optional: enable destructive tests (create/delete resources)
# EVAL_RUN_DESTRUCTIVE=1

# Optional: enable agent judge scoring
# EVAL_AGENT_JUDGE=1

# Optional: generate aggregate report
# EVAL_REPORT=1

# Required for agent judge (when EVAL_AGENT_JUDGE=1)
# ANTHROPIC_API_KEY=
