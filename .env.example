# Required: KWeaver platform URL
KWEAVER_BASE_URL=https://dip.aishu.cn

# Authentication (or set in ~/.env.secrets)
KWEAVER_USERNAME=
KWEAVER_PASSWORD=

# Optional: business domain (default: bd_public)
# KWEAVER_BUSINESS_DOMAIN=bd_public

# Database config for destructive lifecycle tests (or set in ~/.env.secrets)
# KWEAVER_TEST_DB_TYPE=mysql
# KWEAVER_TEST_DB_HOST=
# KWEAVER_TEST_DB_PORT=3306
# KWEAVER_TEST_DB_NAME=
# KWEAVER_TEST_DB_USER=
# KWEAVER_TEST_DB_PASS=

# Optional: enable destructive tests (create/delete resources)
# EVAL_RUN_DESTRUCTIVE=1

# Optional: enable agent judge scoring
# EVAL_AGENT_JUDGE=1

# Optional: generate aggregate report
# EVAL_REPORT=1

# Required for agent judge (when EVAL_AGENT_JUDGE=1)
# ANTHROPIC_API_KEY=
